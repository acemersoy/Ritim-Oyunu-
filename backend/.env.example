# Backend Configuration
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=*
UPLOAD_DIR=./uploads
WAV_DIR=./uploads
DB_PATH=./rhythm_game.db
MAX_UPLOAD_MB=200

# Cloudflare Tunnel
# Get your token from: https://one.dash.cloudflare.com → Networks → Tunnels → Create → Cloudflared → copy token
CLOUDFLARE_TUNNEL_TOKEN=your_tunnel_token_here
